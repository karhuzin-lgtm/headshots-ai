# Скопируй в .env.local и подставь значения (.env.local в .gitignore).

# --- База данных (Neon / Vercel Postgres) -------------------------------------
# ОБЯЗАТЕЛЬНО. Строка подключения к Postgres (Neon). Без неё платный флоу не работает.
DATABASE_URL=
# Vercel-интеграция может вместо этого отдавать POSTGRES_URL.
POSTGRES_URL=

# --- App URL ------------------------------------------------------------------
# Используется в callback-ссылках Astria и в письмах. В проде — реальный домен.
NEXT_PUBLIC_APP_URL=https://headshots.alekseimedia.com

# --- LavaTop (оплата, https://lava.top) ---------------------------------------
# Генерация платная. Цена задаётся в оффере LavaTop (держи в синхроне с PRICE_RUB
# в src/lib/landing-config.ts).
# API-ключ: Integrations -> Public API -> Create API Key.
LAVATOP_API_KEY=
# UUID оффера или ссылка на товар (https://app.lava.top/products/<uuid>) — резолвится в offer id.
LAVATOP_OFFER_ID=
# Секрет вебхука: создай вебхук в Integrations с авторизацией "API key" и пропиши то же
# значение здесь. LavaTop возвращает его в заголовке x-api-key.
# URL вебхука: {NEXT_PUBLIC_APP_URL}/api/webhooks/lavatop
# URL возврата после оплаты: {NEXT_PUBLIC_APP_URL}/try/payment-return
LAVATOP_WEBHOOK_SECRET=
# Валюта списания. По умолчанию RUB. USD/EUR на этом аккаунте могут открывать только PayPal.
LAVATOP_CURRENCY=RUB

# --- Astria (генерация хедшотов) ----------------------------------------------
ASTRIA_API_KEY=
# Добавляется к callback-URL Astria как ?webhook_secret= (кастомные заголовки Astria не шлёт).
ASTRIA_WEBHOOK_SECRET=

# --- Resend (письма-уведомления) ----------------------------------------------
RESEND_API_KEY=

# --- Vercel Blob (загрузка селфи) ---------------------------------------------
BLOB_READ_WRITE_TOKEN=

# --- Необязательное ------------------------------------------------------------
# Внешняя ссылка чекаута; если пусто — главный CTA ведёт на /try/generate.
NEXT_PUBLIC_CHECKOUT_URL=
# Контакт для командных заказов (Telegram/почта).
NEXT_PUBLIC_TEAM_CONTACT_URL=
