# Supabase (anon key + URL required for browser auth; service role for /api jobs)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# In Supabase Dashboard → Authentication → URL config, add:
#   http://localhost:3000/auth/callback
#   (and production) https://your-domain/auth/callback
# Enable Google provider under Authentication → Providers.

# App URL (used for Stripe success/cancel redirects). Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used by fal.ai webhook. For local webhook testing, use an ngrok URL.
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# fal.ai
FAL_KEY=

# Neon / Vercel Postgres
DATABASE_URL=
# Vercel integrations may provide POSTGRES_URL instead of DATABASE_URL.
POSTGRES_URL=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Telegram waitlist notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
